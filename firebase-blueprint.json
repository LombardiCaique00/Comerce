{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Store product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["name", "price", "category", "stock", "isActive", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "User order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "Directory of users"
    },
    "products/{productId}": {
      "schema": { "$ref": "Product" },
      "description": "Directory of products"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "Order" },
      "description": "Directory of orders"
    }
  }
}
